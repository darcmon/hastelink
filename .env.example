# Database
DATABASE_URL=postgresql+asyncpg://hastelink:localdev@localhost:5432/haste_link

# S3 / MinIO (local dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=file-approval
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# S3 / MinIO (production - replace with your actual R2 credentials)
S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=file-approval
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
AWS_REGION=auto

# App
SECRET_KEY=change-me-in-production-use-a-real-secret
ALLOWED_ORIGINS=http://localhost:5173
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Email (MVP: console output, configure SMTP for prod)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
